# ─── Frontend (Vite — prefixo VITE_) ───
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_API_URL=/api
VITE_API_PROXY=http://localhost:3001
VITE_PUBLIC_SITE_URL=https://crashcifras.com.br

# ─── Backend local / Railway ───
PORT=3001
NODE_ENV=development
# Origem do SPA — configurar no Vercel antes do deploy (Settings → Environment Variables)
CLIENT_ORIGIN=https://crashcifras.com.br
FRONTEND_URL=

# Chaves secretas — NUNCA usar prefixo VITE_ (não vão para o bundle)
#
# Anthropic (Claude) — SOMENTE no backend (arquivo .env na raiz do monorepo).
# NÃO existe VITE_ANTHROPIC_API_KEY no frontend.
# Carregamento: backend/config.js → env.anthropicApiKey = process.env.ANTHROPIC_API_KEY
# Uso:
#   • backend/lib/versiculosIa.js — geração de versículos bíblicos (Claude Haiku)
#   • backend/routes/versiculos.js — rota POST /api/versiculos/gerar
ANTHROPIC_API_KEY=
SUPABASE_URL=
SUPABASE_ANON_KEY=
# OBRIGATÓRIO: service role real do Supabase — não use placeholder!
# Começa com eyJ e tem 100+ caracteres. Nunca commitar no git.
SUPABASE_SERVICE_KEY=
INFINITPAY_HANDLE=sos-suspensaohotmailcom
INFINITPAY_WEBHOOK_SECRET=
INFINITPAY_CHECKOUT_API_URL=https://api.infinitepay.io/invoices/public/checkout/links
CRON_SECRET=
# Motor Python do acervo — header x-acervo-motor-secret (fallback: CRON_SECRET)
ACERVO_MOTOR_SECRET=
RESEND_API_KEY=
EMAIL_FROM=CRASH Cifras <noreply@crashcifras.com>

# Worker de importação (Railway — Fase 7)
WORKER_ENABLED=false
RAILWAY_PUBLIC_DOMAIN=
