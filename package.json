{
  "name": "crash-cifras",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "frontend",
    "backend",
    "shared"
  ],
  "scripts": {
    "dev": "concurrently -n web,api -c blue,green \"npm run dev -w frontend\" \"npm run dev -w backend\"",
    "dev:web": "npm run dev -w frontend",
    "dev:api": "npm run dev -w backend",
    "build": "npm run build -w @crash-cifras/frontend",
    "start": "npm run start -w backend",
    "lint": "npm run lint -w frontend",
    "vercel:install": "npm ci && node scripts/ensure-rolldown-binding.mjs"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "supabase": "^2.98.2"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
